---
import type { GetStaticPaths } from 'astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { formatShortDate, getAllTags, getPostUrl, getPublishedPosts } from '../../lib/blog';

export const getStaticPaths: GetStaticPaths = async () => {
  const posts = await getPublishedPosts();
  return getAllTags(posts).map((tag) => ({
    params: { tag: tag.name },
    props: { tagName: tag.name },
  }));
};

const { tagName } = Astro.props;
const posts = await getPublishedPosts();
const tags = getAllTags(posts);
const tagPosts = posts.filter((post) => post.data.tags.includes(tagName));
const tagSize = (count: number) => (count >= 4 ? 'size-lg' : count <= 1 ? 'size-sm' : '');
---

<BaseLayout title={`${tagName} - 标签 - 折页`} description={`浏览折页博客中带有 ${tagName} 标签的文章。`}>
  <section class="tags-hero animate-in">
    <h1>{tagName}</h1>
    <p>共 {tagPosts.length} 篇文章</p>
  </section>

  <div class="tag-cloud animate-in animate-delay-1">
    {tags.map((tag) => (
      <a href={`/tags/${encodeURIComponent(tag.name)}/`} class:list={['cloud-tag', tagSize(tag.count), { active: tag.name === tagName }]}>
        {tag.name} <span class="cloud-tag-count">{tag.count}</span>
      </a>
    ))}
  </div>

  <div class="tag-results animate-in animate-delay-2">
    <div class="tag-results-header">
      <h2>
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="M20.59 13.41l-7.17 7.17a2 2 0 01-2.83 0L2 12V2h10l8.59 8.59a2 2 0 010 2.82z"></path>
          <line x1="7" y1="7" x2="7.01" y2="7"></line>
        </svg>
        {tagName}
      </h2>
      <span class="results-count">共 {tagPosts.length} 篇文章</span>
    </div>

    <div>
      {tagPosts.map((post) => (
        <a href={getPostUrl(post)} class="tag-result-item">
          <span class="tag-result-date">{formatShortDate(post.data.pubDate)}</span>
          <div class="tag-result-body">
            <div class="tag-result-title">{post.data.title}</div>
            <div class="tag-result-excerpt">{post.data.description}</div>
            <div class="tag-result-meta">{post.data.tags.slice(0, 4).map((tag) => <span>#{tag}</span>)}</div>
          </div>
        </a>
      ))}
    </div>
  </div>
</BaseLayout>
