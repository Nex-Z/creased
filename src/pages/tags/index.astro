---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import { getAllTags, getPublishedPosts } from '../../lib/blog';

const posts = await getPublishedPosts();
const tags = getAllTags(posts);
const activeTag = tags[0]?.name;
const activePosts = activeTag ? posts.filter((post) => post.data.tags.includes(activeTag)) : [];
const tagSize = (count: number) => (count >= 4 ? 'size-lg' : count <= 1 ? 'size-sm' : '');
---

<BaseLayout title="标签 - 折页" description="按标签浏览折页博客的所有文章。">
  <section class="tags-hero animate-in">
    <h1>标签</h1>
    <p>通过标签探索感兴趣的内容</p>
  </section>

  <div class="tag-cloud animate-in animate-delay-1">
    {tags.map((tag, index) => (
      <a href={`/tags/${encodeURIComponent(tag.name)}/`} class:list={['cloud-tag', tagSize(tag.count), { active: index === 0 }]}>
        {index === 0 && (
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M20.59 13.41l-7.17 7.17a2 2 0 01-2.83 0L2 12V2h10l8.59 8.59a2 2 0 010 2.82z"></path>
            <line x1="7" y1="7" x2="7.01" y2="7"></line>
          </svg>
        )}
        {tag.name} <span class="cloud-tag-count">{tag.count}</span>
      </a>
    ))}
  </div>

  {activeTag && (
    <div class="tag-results animate-in animate-delay-2">
      <div class="tag-results-header">
        <h2>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M20.59 13.41l-7.17 7.17a2 2 0 01-2.83 0L2 12V2h10l8.59 8.59a2 2 0 010 2.82z"></path>
            <line x1="7" y1="7" x2="7.01" y2="7"></line>
          </svg>
          {activeTag}
        </h2>
        <span class="results-count">共 {activePosts.length} 篇文章</span>
      </div>

      <div class="tag-results-list">
        {activePosts.map((post, index) => (
          <ArticleCard post={post} delay={(index % 4) + 1} />
        ))}
      </div>
    </div>
  )}
</BaseLayout>
