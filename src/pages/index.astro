---
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from '../components/ArticleCard.astro';
import { estimateReadingTime, formatShortDate, getPostUrl, getPublishedPosts } from '../lib/blog';
import { SITE } from '../lib/site';

const posts = await getPublishedPosts();
const featuredPosts = posts.filter((post) => post.data.featured).slice(0, 2);
const latestPosts = posts.filter((post) => !post.data.featured).slice(0, 3);
const earlierPosts = posts.filter((post) => !post.data.featured).slice(3, 8);
---

<BaseLayout title={SITE.title} description={SITE.description} bodyClass="home-page">
  <div class="dot-bg" aria-hidden="true"></div>

  <section class="hero">
    <div class="hero-content animate-in">
      <h1>记录思考的折痕</h1>
      <p>每一次思考都是一次折叠，留下痕迹，成为记忆。这里记录技术探索、设计感悟与日常灵感。</p>
    </div>
  </section>

  <section class="section">
    <h2 class="section-title animate-in">置顶推荐</h2>
    <div class="feed-list">
      {featuredPosts.map((post, index) => (
        <ArticleCard post={post} featured delay={index + 1} />
      ))}
    </div>
  </section>

  <section class="section">
    <h2 class="section-title animate-in">最新文章</h2>
    <div class="feed-list">
      {latestPosts.map((post, index) => (
        <ArticleCard post={post} delay={index + 1} />
      ))}
    </div>
    <div class="section-footer animate-in animate-delay-4">
      <a href="/archive/" class="btn-view-all">浏览全部文章 →</a>
    </div>
  </section>

  <section class="section">
    <h2 class="section-title animate-in">更早的文章</h2>
    <div class="post-list-minimal animate-in animate-delay-1">
      {earlierPosts.map((post) => (
        <a class="post-row" href={getPostUrl(post)}>
          <div class="row-left">
            <span class="row-title">{post.data.title}</span>
          </div>
          <div class="row-right">
            <span>{estimateReadingTime(post.body)}</span>
            <span>{formatShortDate(post.data.pubDate)}</span>
          </div>
        </a>
      ))}
    </div>
    <div class="section-footer animate-in animate-delay-2">
      <a href="/archive/" class="btn-view-all">前往归档页探索全部文章 →</a>
    </div>
  </section>
</BaseLayout>
