---
import type { BlogPost } from '../lib/blog';
import { estimateReadingTime, getPostUrl } from '../lib/blog';

interface Props {
  post: BlogPost;
  featured?: boolean;
  delay?: number;
}

const { post, featured = false, delay = 1 } = Astro.props;
const delayClass = `animate-delay-${Math.min(Math.max(delay, 1), 4)}`;
---

<a href={getPostUrl(post)} class:list={['feed-card', { 'featured-badge': featured }, 'animate-in', delayClass]}>
  {post.data.cover && (
    <div class="card-image">
      <img src={post.data.cover} alt={post.data.coverAlt ?? post.data.title} loading="lazy" />
    </div>
  )}
  <div class="card-body">
    <h3 class="card-title">{post.data.title}</h3>
    <p class="card-excerpt">{post.data.description}</p>
    <div class="card-footer">
      <span class="compact-tags">
        {post.data.tags.slice(0, 3).map((tag) => <span class="hash-tag">{tag}</span>)}
      </span>
      <span class="read-time">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="12" cy="12" r="10"></circle>
          <polyline points="12 6 12 12 16 14"></polyline>
        </svg>
        {estimateReadingTime(post.body)}
      </span>
    </div>
  </div>
</a>
